# Google Gemini API Key
# https://makersuite.google.com/app/apikey で取得してください
GEMINI_API_KEY=your_api_key_here

# Gemini モデル選択（オプション）
# gemini-3-flash: 最新版（デフォルト、2025年12月リリース、最高性能・高速）
# gemini-2.5-flash: 安定版（2025年GA）
# gemini-2.0-flash-exp: 旧版（2026年2月廃止予定）
# GEMINI_MODEL=gemini-3-flash

# Firebase Configuration (Frontend)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Firebase Admin (Backend)
# Set the path to your service account json file, or encode it as a base64 string
FIREBASE_SERVICE_ACCOUNT=path/to/serviceAccountKey.json

# Stripe Configuration
# https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
