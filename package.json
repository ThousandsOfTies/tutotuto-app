    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "cropperjs": "^2.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "fabric": "^5.3.0",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "heic2any": "^0.0.4",
    "i18next": "^25.7.4",
    "i18next-http-backend": "^3.0.2",
    "jspdf": "^3.0.4",
