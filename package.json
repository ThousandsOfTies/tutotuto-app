{
  "name": "tutotuto",
  "version": "0.2.7",
  "private": true,
  "description": "AI-powered drill grading app with handwriting support",
  "type": "module",
  "scripts": {
    "dev": "vite --mode kids",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
